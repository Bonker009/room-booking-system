BETTER_AUTH_SECRET="your-better-auth-secret"

BETTER_AUTH_URL=http://localhost:3000

KEYCLOAK_CLIENT_ID=room-booking
KEYCLOAK_CLIENT_SECRET="your-keycloak-client-secret"
KEYCLOAK_ISSUER=

# Optional: booking rules (defaults shown)
# BOOKING_WORK_START=08:00
# BOOKING_WORK_END=18:00
# BOOKING_MIN_MINUTES=30
# BOOKING_MAX_MINUTES=480
# BOOKING_MAX_DAYS_AHEAD=90

# Optional: webhook for booking notifications (Slack, Teams, etc.)
# BOOKING_NOTIFY_WEBHOOK=https://example.com/hooks/booking-notify
